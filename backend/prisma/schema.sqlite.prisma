generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         String   @default("admin")
  createdAt    DateTime @default(now())
  petitions    Petition[]
  auditLogs    AuditLog[]
  exports      Export[]
}

model Petition {
  id                    String      @id @default(uuid())
  slug                  String      @unique
  title                 String
  summary               String
  body                  String
  recipientName         String
  recipientDescription  String?
  status                String      @default("draft")
  goalCount             Int?
  allowPublicNames      Boolean     @default(false)
  allowComments         Boolean     @default(false)
  requireVerification   Boolean     @default(true)
  startsAt              DateTime?
  endsAt                DateTime?
  createdBy             String
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  creator               User        @relation(fields: [createdBy], references: [id])
  signatures            Signature[]
  exports               Export[]
}

model Signature {
  id                    String    @id @default(uuid())
  petitionId            String
  fullName              String
  email                 String
  city                  String?
  country               String?
  comment               String?
  verified              Boolean   @default(false)
  withdrawn             Boolean   @default(false)
  publicOptIn           Boolean   @default(false)
  updatesOptIn          Boolean   @default(false)
  recipientShareOptIn   Boolean   @default(false)
  createdAt             DateTime  @default(now())
  verifiedAt            DateTime?
  withdrawnAt           DateTime?
  petition              Petition  @relation(fields: [petitionId], references: [id])
  verificationTokens    VerificationToken[]

  @@unique([petitionId, email])
}

model VerificationToken {
  id          String    @id @default(uuid())
  signatureId String
  tokenHash   String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())
  type        String    @default("verify")
  signature   Signature @relation(fields: [signatureId], references: [id])
}

model Export {
  id          String    @id @default(uuid())
  petitionId  String?
  createdBy   String
  format      String
  filtersJson String?
  createdAt   DateTime  @default(now())
  petition    Petition? @relation(fields: [petitionId], references: [id])
  creator     User      @relation(fields: [createdBy], references: [id])
}

model AuditLog {
  id           String   @id @default(uuid())
  actorId      String?
  action       String
  entityType   String
  entityId     String
  metadataJson String?
  createdAt    DateTime @default(now())
  actor        User?    @relation(fields: [actorId], references: [id])
}
