generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         String   @default("admin")
  createdAt    DateTime @default(now())
  petitions    Petition[]
  petitionAccess PetitionUserAccess[]
  auditLogs    AuditLog[]
  exports      Export[]
  petitionUpdatesCreated          PetitionUpdate[]        @relation("PetitionUpdateCreatedBy")
  petitionUpdatesUpdated          PetitionUpdate[]        @relation("PetitionUpdateUpdatedBy")
  petitionUpdatesDeleted          PetitionUpdate[]        @relation("PetitionUpdateDeletedBy")
  petitionUpdateVersionsPublished PetitionUpdateVersion[] @relation("PetitionUpdateVersionPublishedBy")
}

model Petition {
  id                    String      @id @default(uuid())
  slug                  String      @unique
  title                 String
  summary               String
  body                  String
  recipientName         String
  recipientDescription  String?
  status                String      @default("draft")
  goalCount             Int?
  allowPublicNames      Boolean     @default(false)
  allowComments         Boolean     @default(false)
  requireVerification   Boolean     @default(true)
  startsAt              DateTime?
  endsAt                DateTime?
  createdBy             String
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  creator               User        @relation(fields: [createdBy], references: [id])
  userAccess            PetitionUserAccess[]
  signatures            Signature[]
  exports               Export[]
  updates               PetitionUpdate[]
}

model PetitionUpdate {
  id              String                 @id @default(uuid())
  petitionId      String
  currentTitle    String
  currentContent  String
  lastPublishedAt DateTime?
  createdBy       String
  updatedBy       String?
  deletedAt       DateTime?
  deletedBy       String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  petition        Petition               @relation(fields: [petitionId], references: [id])
  creator         User                   @relation("PetitionUpdateCreatedBy", fields: [createdBy], references: [id])
  updater         User?                  @relation("PetitionUpdateUpdatedBy", fields: [updatedBy], references: [id])
  deleter         User?                  @relation("PetitionUpdateDeletedBy", fields: [deletedBy], references: [id])
  versions        PetitionUpdateVersion[]

  @@index([petitionId, createdAt])
}

model PetitionUpdateVersion {
  id               String         @id @default(uuid())
  petitionUpdateId String
  versionNumber    Int
  title            String
  content          String
  publishedAt      DateTime       @default(now())
  publishedBy      String
  petitionUpdate   PetitionUpdate @relation(fields: [petitionUpdateId], references: [id])
  publisher        User           @relation("PetitionUpdateVersionPublishedBy", fields: [publishedBy], references: [id])

  @@unique([petitionUpdateId, versionNumber])
  @@index([petitionUpdateId, publishedAt])
}

model PetitionUserAccess {
  id         String   @id @default(uuid())
  userId     String
  petitionId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  petition   Petition @relation(fields: [petitionId], references: [id], onDelete: Cascade)

  @@unique([userId, petitionId])
}

model Signature {
  id                    String    @id @default(uuid())
  petitionId            String
  fullName              String
  email                 String
  city                  String?
  country               String?
  comment               String?
  verified              Boolean   @default(false)
  withdrawn             Boolean   @default(false)
  publicOptIn           Boolean   @default(false)
  updatesOptIn          Boolean   @default(false)
  recipientShareOptIn   Boolean   @default(false)
  createdAt             DateTime  @default(now())
  verifiedAt            DateTime?
  withdrawnAt           DateTime?
  petition              Petition  @relation(fields: [petitionId], references: [id])
  verificationTokens    VerificationToken[]

  @@unique([petitionId, email])
}

model VerificationToken {
  id          String    @id @default(uuid())
  signatureId String
  tokenHash   String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())
  type        String    @default("verify")
  signature   Signature @relation(fields: [signatureId], references: [id])
}

model Export {
  id          String    @id @default(uuid())
  petitionId  String?
  createdBy   String
  format      String
  filtersJson String?
  createdAt   DateTime  @default(now())
  petition    Petition? @relation(fields: [petitionId], references: [id])
  creator     User      @relation(fields: [createdBy], references: [id])
}

model AuditLog {
  id           String   @id @default(uuid())
  actorId      String?
  action       String
  entityType   String
  entityId     String
  metadataJson String?
  createdAt    DateTime @default(now())
  actor        User?    @relation(fields: [actorId], references: [id])
}
