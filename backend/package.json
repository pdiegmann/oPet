{
  "name": "opet-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "predev": "bun run scripts/prepare-db.ts",
    "start": "bun run src/index.ts",
    "prestart": "bun run scripts/prepare-db.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "db:setup": "bun run scripts/prepare-db.ts",
    "db:generate": "bunx prisma generate",
    "db:migrate": "bunx prisma migrate deploy",
    "db:push": "bunx prisma db push",
    "db:seed": "bun run prisma/seed.ts",
    "test": "bun test"
  },
  "dependencies": {
    "@prisma/client": "^7.7.0",
    "bcryptjs": "^3.0.3",
    "csv-stringify": "^6.7.0",
    "hono": "^4.12.14",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^6.4.17",
    "prisma": "^7.7.0",
    "typescript": "^5.9.3"
  }
}
